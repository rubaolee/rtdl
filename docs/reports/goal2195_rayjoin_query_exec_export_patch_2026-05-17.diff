+
+static void WriteQueryStreamPrefix(std::ofstream& out,
+                                   const QueryConfig& config,
+                                   const char* workload,
+                                   size_t query_count) {
+  out << std::setprecision(17);
+  out << "{\n";
+  out << "  \"base_cdb\": \"" << config.map_path << "\",\n";
+  out << "  \"claim_boundary\": {\n";
+  out << "    \"paper_scale_perf_claim_authorized\": false,\n";
+  out << "    \"rtdl_beats_rayjoin_claim_authorized\": false,\n";
+  out << "    \"same_contract_with_rayjoin_query_exec\": true,\n";
+  out << "    \"v2_0_release_authorized\": false\n";
+  out << "  },\n";
+  out << "  \"producer\": \"rayjoin_query_exec_export_patch\",\n";
+  out << "  \"query_count\": " << query_count << ",\n";
+  out << "  \"rayjoin_query_exec_flags\": {\n";
+  out << "    \"gen_n\": " << config.gen_n << ",\n";
+  out << "    \"gen_t\": " << config.gen_t << ",\n";
+  out << "    \"mode\": \"" << config.mode << "\",\n";
+  out << "    \"poly1\": \"" << config.map_path << "\",\n";
+  out << "    \"query\": \"" << workload << "\",\n";
+  out << "    \"seed\": " << config.random_seed << "\n";
+  out << "  },\n";
+  out << "  \"queries\": [\n";
+}
+
+static void WriteQueryStreamSuffix(std::ofstream& out,
+                                   const char* workload) {
+  out << "\n";
+  out << "  ],\n";
+  out << "  \"schema\": \"rtdl.rayjoin.same_query_stream.v1\",\n";
+  out << "  \"workload\": \"" << workload << "\"\n";
+  out << "}\n";
+}
+
+template <typename POINT_T, typename EDGE_T>
+static void MaybeExportLSIQueryStream(const QueryConfig& config,
+                                      const pinned_vector<POINT_T>& points,
+                                      const pinned_vector<EDGE_T>& edges) {
+  if (!HasQueryStreamOutput(config)) {
+    return;
+  }
+  std::ofstream out(config.query_stream_output);
+  CHECK(out) << "Failed to open query stream output: "
+             << config.query_stream_output;
+  WriteQueryStreamPrefix(out, config, "lsi", edges.size());
+  for (size_t i = 0; i < edges.size(); i++) {
+    const auto& edge = edges[i];
+    const auto& p0 = points[edge.p1_idx];
+    const auto& p1 = points[edge.p2_idx];
+    out << "    {\"id\": " << edge.eid << ", \"x0\": " << p0.x
+        << ", \"x1\": " << p1.x << ", \"y0\": " << p0.y
+        << ", \"y1\": " << p1.y << "}";
+    if (i + 1 != edges.size()) {
+      out << ",";
+    }
+    out << "\n";
+  }
+  WriteQueryStreamSuffix(out, "lsi");
+}
+
+static void MaybeExportPIPQueryStream(
+    const QueryConfig& config,
+    const std::vector<std::pair<double, double>>& unscaled_points) {
+  if (!HasQueryStreamOutput(config)) {
+    return;
+  }
+  std::ofstream out(config.query_stream_output);
+  CHECK(out) << "Failed to open query stream output: "
+             << config.query_stream_output;
+  WriteQueryStreamPrefix(out, config, "pip", unscaled_points.size());
+  for (size_t i = 0; i < unscaled_points.size(); i++) {
+    out << "    {\"id\": " << i << ", \"x\": "
+        << unscaled_points[i].first << ", \"y\": "
+        << unscaled_points[i].second << "}";
+    if (i + 1 != unscaled_points.size()) {
+      out << ",";
+    }
+    out << "\n";
+  }
+  WriteQueryStreamSuffix(out, "pip");
+}
