+static std::string JsonEscape(const std::string& value) {
+  std::ostringstream out;
+  for (char ch : value) {
+    switch (ch) {
+      case '\\':
+        out << "\\\\";
+        break;
+      case '"':
+        out << "\\\"";
+        break;
+      case '\n':
+        out << "\\n";
+        break;
+      case '\r':
+        out << "\\r";
+        break;
+      case '\t':
+        out << "\\t";
+        break;
+      default:
+        out << ch;
+        break;
+    }
+  }
+  return out.str();
+}
+
+static void BeginQueryStream(std::ofstream& out, const QueryConfig& config,
+                             const char* workload) {
+  out << std::setprecision(17);
+  out << "{\n"
+      << "  \"schema\": \"rtdl.rayjoin.same_query_stream.v1\",\n"
+      << "  \"producer\": \"rayjoin_query_exec_export_patch\",\n"
+      << "  \"workload\": \"" << workload << "\",\n"
+      << "  \"base_cdb\": \"" << JsonEscape(config.map_path) << "\",\n"
+      << "  \"rayjoin_query_exec_flags\": {\n"
+      << "    \"poly1\": \"" << JsonEscape(config.map_path) << "\",\n"
+      << "    \"query\": \"" << workload << "\",\n"
+      << "    \"gen_n\": " << config.gen_n << ",\n"
+      << "    \"gen_t\": " << config.gen_t << ",\n"
+      << "    \"seed\": " << config.random_seed << "\n"
+      << "  },\n"
+      << "  \"query_count\": " << config.gen_n << ",\n"
+      << "  \"queries\": [\n";
+}
+
+static void EndQueryStream(std::ofstream& out) {
+  out << "\n"
+      << "  ],\n"
+      << "  \"claim_boundary\": {\n"
+      << "    \"same_contract_with_rayjoin_query_exec\": true,\n"
+      << "    \"paper_scale_perf_claim_authorized\": false,\n"
+      << "    \"rtdl_beats_rayjoin_claim_authorized\": false,\n"
+      << "    \"v2_0_release_authorized\": false\n"
+      << "  }\n"
+      << "}\n";
+}
